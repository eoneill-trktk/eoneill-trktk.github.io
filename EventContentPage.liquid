{%- assign pagedata = Model.CurrentPage | get_page -%}
{%- assign templatePath = "includes/SiteHeaderLayout.liquid" | get_templatepath -%}
{%- include templatePath, Model: Model -%}

{%- comment %} ── Date/time setup ─────────────────────────────────────── {%- endcomment %}
{%- assign startd  = Model.CurrentPage.EventStartDate | date: "%Y-%m-%d" -%}
{%- assign startdd = Model.CurrentPage.EventStartTime | time_zone: "America/New_York" | date: "%H:%M:%S" -%}
{%- assign endd    = Model.CurrentPage.EventEndDate   | date: "%Y-%m-%d" -%}
{%- assign enddd   = Model.CurrentPage.EventEndTime   | time_zone: "America/New_York" | date: "%H:%M:%S" -%}
{%- if Model.CurrentPage.EventSeries != null -%}
  {%- for item in Model.CurrentPage.EventSeries reversed -%}
    {%- assign endd       = item.EventItemStartDate | date: "%Y-%m-%d" -%}
    {%- assign enddd      = item.EventItemEndTime   | time_zone: "America/New_York" | date: "%H:%M:%S" -%}
    {%- assign fullendate = endd | append: 'T' | append: enddd | append: "Z" -%}
  {%- endfor -%}
{%- else -%}
  {%- assign fullendate = endd | append: 'T' | append: enddd | append: "Z" -%}
{%- endif -%}
{%- assign compareendate = fullendate | date: "%s" | times: 1 -%}
{%- assign nowunix       = 'now'      | date: "%s" | times: 1 -%}
{%- assign zone          = startzone  | time_zone: "America/New_York" | date: "%Z" -%}
{%- assign path          = Model.CurrentPage | url -%}
{%- assign domain        = Model.CurrentPage | domain_url -%}
{%- assign website       = domain | append: path -%}

{%- comment %} ── Section detection: resources vs news ─────────────────── {%- endcomment %}
{%- assign yearFolder    = ContentLoader.Get(Model.CurrentPage.ParentLink) -%}
{%- assign sectionPage   = ContentLoader.Get(yearFolder.ParentLink) -%}
{%- assign sectionSegment = sectionPage.URLSegment | downcase -%}
{%- assign pageSection   = "resources" -%}
{%- if sectionSegment == "all-mtf-news" -%}
  {%- assign pageSection = "news" -%}
{%- endif -%}

{%- comment %} ── Sidebar: find /topics/ or /category/ folder from site root ── {%- endcomment %}
{%- assign siteRootChildren = ContentLoader.GetChildren(sectionPage.ParentLink) -%}
{%- assign sidebarRef   = null -%}
{%- assign sidebarTitle = "Topics" -%}
{%- assign sidebarBase  = "/topics/" -%}
{%- assign sectionLabel = "Resource Library" -%}
{%- assign sectionUrl   = "/resources/" -%}
{%- if pageSection == "news" -%}
  {%- assign sidebarTitle = "News Categories" -%}
  {%- assign sidebarBase  = "/category/" -%}
  {%- assign sectionLabel = "MTF News" -%}
  {%- assign sectionUrl   = "/all-mtf-news/" -%}
  {%- for child in siteRootChildren -%}
    {%- if child.URLSegment == "category" -%}
      {%- assign sidebarRef = child.ContentLink -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- else -%}
  {%- for child in siteRootChildren -%}
    {%- if child.URLSegment == "topics" -%}
      {%- assign sidebarRef = child.ContentLink -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
{%- assign sidebarPages = ContentLoader.GetChildren(sidebarRef) -%}

{%- comment %} ── Determine the relevant category parent name ──────────── {%- endcomment %}
{%- assign catGroupName = "Resources" -%}
{%- if pageSection == "news" -%}
  {%- assign catGroupName = "News" -%}
{%- endif -%}

<main id="main" class="site-main event-page clean-n-simple">
  <section>
    <div class="main-content grid-container" itemscope itemtype="http://schema.org/Event">
      {{ Property.For(Model=Model.CascadingContent["crumbtrail"]
            , PropertyName = "crumbtrail"
            , HasContainer=false
            , UseItemContainer=false) }}

      {%- if compareendate != 0 and compareendate < nowunix -%}
        <div class="event-passed standard-width">This event has passed.</div>
      {%- endif -%}

      <div class="zak-page-header zak-style-1">
        <div class="zak-container">
          <div class="zak-row">
            <div class="zak-page-header__title">
              <h1 class="zak-page-title">
                {%- if Model.PageTitle != null or CmsContext.IsInEditMode -%}
                  <span {{ CmsHelper.EditAttributes("PageTitle") }}>{{ Model.PageTitle }}</span>
                {%- endif -%}
              </h1>
            </div>
          </div>
        </div>
      </div>

      {%- comment %} ── Two-column layout ────────────────────────────────── {%- endcomment %}
      <div class="event-content-layout standard-width">

        <div class="event-content-main">

          {%- comment %} ── Topic/s: line ─────────────────────────────────── {%- endcomment %}
          {%- assign hasTopicLinks = false -%}
          {%- if pagedata.Categories != null -%}
            {%- for item in pagedata.Categories -%}
              {%- assign parentCat = ContentLoader.Get(item.ParentLink) -%}
              {%- if parentCat != null and parentCat.Name == catGroupName -%}
                {%- assign hasTopicLinks = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          {%- if hasTopicLinks -%}
          <div class="ctl">
            <span><b>Topic/s:</b></span>
            <span class="custom-taxonomy-list">
              {%- assign topicIndex = 0 -%}
              {%- for item in pagedata.Categories -%}
                {%- assign parentCat = ContentLoader.Get(item.ParentLink) -%}
                {%- if parentCat != null and parentCat.Name == catGroupName -%}
                  {%- assign itemSlug = item.Name | downcase | replace: " ", "-" -%}
                  {%- if topicIndex > 0 -%},&nbsp;{% endif %}<a href="{{ sidebarBase }}{{ itemSlug }}/">{{ item.Name }}</a>
                  {%- assign topicIndex = topicIndex | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            </span>
          </div>
          {%- endif -%}

          {%- comment %} ── Location ─────────────────────────────────────── {%- endcomment %}
          {%- if Model.CurrentPage.EventSeries != null -%}
            {%- for item in Model.CurrentPage.EventSeries -%}
              {%- if item.EventItemLocationData != null -%}
                {%- assign eventlocation = ContentLoader.Get(item.EventItemLocationData) -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          {%- if eventlocation != null -%}
            <div class="location">
              <h4>Location</h4>
              <div class="location-name">
                <span>{{ eventlocation.LocationDisplayName }}</span>
                {%- if eventlocation.MapUrl != null -%}
                  {%- assign target = "_self" -%}
                  {%- if eventlocation.MapUrl.LinkTarget != null -%}{%- assign target = eventlocation.MapUrl.LinkTarget -%}{%- endif -%}
                  <a href="{{ eventlocation.MapUrl.LinkDetailUrl | url }}" target="{{ target }}" title="find location on map">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512"><path fill="currentColor" d="M408 120c0 54.6-73.1 151.9-105.2 192c-7.7 9.6-22 9.6-29.6 0C241.1 271.9 168 174.6 168 120C168 53.7 221.7 0 288 0s120 53.7 120 120zm8 80.4c3.5-6.9 6.7-13.8 9.6-20.6c.5-1.2 1-2.5 1.5-3.7l116-46.4C558.9 123.4 576 135 576 152l0 270.8c0 9.8-6 18.6-15.1 22.3L416 503l0-302.6zM137.6 138.3c2.4 14.1 7.2 28.3 12.8 41.5c2.9 6.8 6.1 13.7 9.6 20.6l0 251.4L32.9 502.7C17.1 509 0 497.4 0 480.4L0 209.6c0-9.8 6-18.6 15.1-22.3l122.6-49zM327.8 332c13.9-17.4 35.7-45.7 56.2-77l0 249.3L192 449.4 192 255c20.5 31.3 42.3 59.6 56.2 77c20.5 25.6 59.1 25.6 79.6 0zM288 152a40 40 0 1 0 0-80 40 40 0 1 0 0 80z"/></svg>
                  </a>
                {%- endif -%}
              </div>
              <div class="location-address">
                {%- if eventlocation.LocationAddress != null -%}<span>{{ eventlocation.LocationAddress }}</span>{%- endif -%}
                {%- if eventlocation.LocationCity != null -%}<span>, {{ eventlocation.LocationCity }}</span>{%- endif -%}
                {%- if eventlocation.LocationStateProvince != null -%}<span> {{ eventlocation.LocationStateProvince }}</span>{%- endif -%}
                {%- if eventlocation.LocationPostalCode != null -%}<span>, {{ eventlocation.LocationPostalCode }}</span>{%- endif -%}
                {%- if eventlocation.LocationCountry != null -%}<span> {{ eventlocation.LocationCountry }}</span>{%- endif -%}
              </div>
            </div>
          {%- endif -%}

          {%- comment %} ── Hero image (only if uploaded — no placeholder fallback) ── {%- endcomment %}
          {%- if Model.HeroImageFile != null or CmsContext.IsInEditMode -%}
            {%- assign pageImg = Model.HeroImageFile | get_image -%}
            {%- if pageImg != null -%}
            <div class="event-image" {{ CmsHelper.EditAttributes("HeroImageFile") }}>
              <img src="{{ pageImg.Url }}" alt="{{ pageImg.ImgAlt }}" loading="lazy">
            </div>
            {%- endif -%}
          {%- endif -%}

          {%- comment %} ── Main content ──────────────────────────────────── {%- endcomment %}
          {{ Property.For(Model=Model.MainContentArea
            , PropertyName = "MainContentArea"
            , HasContainer=false
            , UseItemContainer=false) }}

          {%- comment %} ── Registration link ─────────────────────────────── {%- endcomment %}
          {%- assign target = "_self" -%}
          {%- if Model.CurrentPage.EventLinkitem != null or CmsContext.IsInEditMode -%}
            {%- if Model.CurrentPage.EventLinkitem.Target != null -%}
              {%- assign target = Model.CurrentPage.EventLinkitem.Target -%}
            {%- endif -%}
            <div class="registration" {{ CmsHelper.EditAttributes("EventLinkitem") }}>
              <a class="bttn" href="{{ Model.CurrentPage.EventLinkitem.Href }}"
                title="{{ Model.CurrentPage.EventLinkitem.Title }}" target="{{ target }}">
                {{ Model.CurrentPage.EventLinkitem.Text }}
              </a>
            </div>
          {%- endif -%}

          {%- comment %} ── Add to calendar ───────────────────────────────── {%- endcomment %}
          <div>
            {%- if Model.CurrentPage.EventSeries != null -%}
              <add-to-calendar-button
                name="{{ Model.PageTitle }}"
                options="'Apple','Google','iCal','Outlook.com','Yahoo'"
                location="{{ eventlocation.LocationDisplayName }}"
                dates='[
                {%- for item in Model.CurrentPage.EventSeries -%}
                  {%- assign startd  = item.EventItemStartDate | date: "%Y-%m-%d" -%}
                  {%- assign startdd = item.EventItemStartTime | time_zone: "America/New_York" | date: "%H:%M:%S" -%}
                  {%- assign endd    = item.EventItemStartDate | date: "%Y-%m-%d" -%}
                  {%- assign enddd   = item.EventItemEndTime   | time_zone: "America/New_York" | date: "%H:%M:%S" -%}
                  {
                    "name":"{{ item.EventItemName }}",
                    "description":"[url]{{ website }}|Event details page[/url]",
                    "startDate":"{{ startd }}",
                    "startTime":"{{ startdd }}",
                    "endTime":"{{ enddd }}"
                  }{% if forloop.last != true %},{% endif %}
                {%- endfor -%}
                ]'
                timeZone="America/New_York">
              </add-to-calendar-button>
            {%- else -%}
              <add-to-calendar-button
                name="{{ Model.PageTitle }}"
                options="'Apple','Google','iCal','Outlook.com','Yahoo'"
                location="{{ eventlocation.LocationDisplayName }}"
                startDate="{{ startd }}"
                endDate="{{ endd }}"
                startTime="{{ startdd }}"
                endTime="{{ enddd }}"
                timeZone="America/New_York"
                description="[url]{{ website }}|Event details page[/url]">
              </add-to-calendar-button>
            {%- endif -%}
          </div>

          {%- comment %} ── Posted on / Posted in ─────────────────────────── {%- endcomment %}
          <div class="zak-entry-meta">
            <span class="zak-posted-on">Posted on
              <time>{{ pagedata.ContentPostedDate | date: "%B %-d, %Y" }}</time>
            </span>
            <span class="zak-cat-links">Posted in
              <a href="{{ sectionUrl }}">{{ sectionLabel }}</a>
            </span>
          </div>

        </div>{%- comment %} /.event-content-main {%- endcomment %}

        {%- comment %} ── Sidebar ───────────────────────────────────────── {%- endcomment %}
        <aside class="event-content-sidebar">
          <section class="widget widget-sidebar-right">
            <h2 class="widget-title">{{ sidebarTitle }}</h2>
            {%- if sidebarPages != null and sidebarPages.size > 0 -%}
            <ul class="sidebar-topics-list">
              {%- for sidebarPage in sidebarPages -%}
              <li>
                <a href="{{ sidebarBase }}{{ sidebarPage.URLSegment }}/">{{ sidebarPage.Name }}</a>
              </li>
              {%- endfor -%}
            </ul>
            {%- endif -%}
          </section>
        </aside>

      </div>{%- comment %} /.event-content-layout {%- endcomment %}

    </div>
    {% assign templatePath = "includes/RelatedLinks.liquid" | get_templatepath %}
    {% include templatePath, Model: Model %}
  </section>
</main>

{% assign templatePath = "includes/footer.liquid" | get_templatepath %}
{% include templatePath, Model: Model %}

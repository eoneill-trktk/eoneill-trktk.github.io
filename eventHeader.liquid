{%- comment %} pageContext passed in from EventSectionPage.liquid {%- endcomment %}

{%- comment %} ── Context-aware labels ─────────────────────────────────── {%- endcomment %}
{%- assign allLabel         = "All Topics" -%}
{%- assign searchPlaceholder = "Search resources…" -%}
{%- if pageContext == "news" or pageContext == "category" -%}
  {%- assign allLabel          = "All MTF News" -%}
  {%- assign searchPlaceholder = "Search this News category…" -%}
{%- endif -%}

{%- comment %} ── Route and search term ────────────────────────────────── {%- endcomment %}
{%- if pageContext == "archives" or pageContext == "topics" or pageContext == "category" -%}
  {%- assign currentRoute      = Model.CurrentPage | url -%}
  {%- assign currentSearchTerm = "" -%}
{%- else -%}
  {%- assign listingModel = Model.ExtendedPageProperties["PageListingModel"] -%}
  {%- if listingModel != null -%}
    {%- assign currentRoute      = listingModel.ActivePageRoute | friendly_url -%}
    {%- assign currentSearchTerm = listingModel.CurrentSearchTerm -%}
  {%- else -%}
    {%- assign currentRoute      = Model.CurrentPage | url -%}
    {%- assign currentSearchTerm = "" -%}
  {%- endif -%}
{%- endif -%}

{%- comment %} ── Topic/category slug from URLSegment ──────────────────── {%- endcomment %}
{%- assign topicSlug = "" -%}
{%- if pageContext == "topics" or pageContext == "category" -%}
  {%- assign topicSlug = Model.CurrentPage.URLSegment | downcase -%}
{%- endif -%}

{%- comment %} ── Dynamic year calculation ─────────────────────────────── {%- endcomment %}
{%- assign currentYear    = 'now' | date: "%Y" | plus: 0 -%}
{%- assign priorYear      = currentYear | minus: 1 -%}
{%- assign archiveMaxYear = currentYear | minus: 2 -%}

<form id="resource-filter-form" class="resource-filters" method="get" action="{{ currentRoute }}"
  data-page-context="{{ pageContext }}"
  data-topic-slug="{{ topicSlug }}"
  data-current-year="{{ currentYear }}">

  <select id="category-filter" class="filter-select">
    <option value="">{{ allLabel }}</option>
    {%- if pageContext == "topics" or pageContext == "category" or pageContext == "news" -%}
      {%- comment %} Use page Categories (parent = filter group) {%- endcomment %}
      {%- for catRef in Model.CurrentPage.Categories -%}
        {%- assign catChildList = ContentLoader.GetChildren(catRef) -%}
        {%- if catChildList and catChildList.size > 0 -%}
          {%- for catChild in catChildList -%}
            {%- assign catSlug = catChild.Name | downcase | replace: " ", "-" -%}
            <option value="{{ catChild.ContentLink }}" data-slug="{{ catSlug }}">{{ catChild.Name }}</option>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    {%- elsif Model.CurrentPage.AvailableFilterBy != null and Model.CurrentPage.AvailableFilterBy.size > 0 -%}
      {%- comment %} Use AvailableFilterBy if configured in CMS {%- endcomment %}
      {%- for catref in Model.CurrentPage.AvailableFilterBy -%}
        {%- assign catChildList = ContentLoader.GetChildren(catref) -%}
        {%- for catChild in catChildList -%}
          {%- assign catSlug = catChild.Name | downcase | replace: " ", "-" -%}
          <option value="{{ catChild.ContentLink }}" data-slug="{{ catSlug }}">{{ catChild.Name }}</option>
        {%- endfor -%}
      {%- endfor -%}
    {%- else -%}
      {%- comment %} Fallback: use page Categories (archives/news with category group tagged) {%- endcomment %}
      {%- for catRef in Model.CurrentPage.Categories -%}
        {%- assign catChildList = ContentLoader.GetChildren(catRef) -%}
        {%- if catChildList and catChildList.size > 0 -%}
          {%- for catChild in catChildList -%}
            {%- assign catSlug = catChild.Name | downcase | replace: " ", "-" -%}
            <option value="{{ catChild.ContentLink }}" data-slug="{{ catSlug }}">{{ catChild.Name }}</option>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </select>

  <select id="year-filter" class="filter-select">
    <option value="">All Years</option>
    {%- if pageContext == "archives" -%}
      {%- assign y = archiveMaxYear -%}
      {%- for i in (1..10) -%}
        {%- if y >= 2020 -%}
          <option value="{{ y }}">{{ y }}</option>
          {%- assign y = y | minus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      <option value="{{ currentYear }}">{{ currentYear }}</option>
      <option value="{{ priorYear }}">{{ priorYear }}</option>
    {%- endif -%}
  </select>

  <input type="search" id="search-filter" name="searchTerm"
    placeholder="{{ searchPlaceholder }}"
    value="{{ currentSearchTerm }}" class="filter-search-input">

  <input type="hidden" name="viewType" value="list">
  {%- unless pageContext == "archives" or pageContext == "topics" or pageContext == "category" -%}
  <input type="hidden" name="startDate" value="2020-01-01">
  {%- endunless -%}

  <button type="submit" id="filter-button" class="filter-button">Filter</button>

  <a href="{{ currentRoute }}" id="clear-filters" class="clear-button" style="display:none;">Clear All</a>

</form>

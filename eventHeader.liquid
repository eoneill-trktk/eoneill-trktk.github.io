{%- assign currentRoute = Model.ExtendedPageProperties["PageListingModel"].ActivePageRoute | friendly_url -%}
{%- assign currentSearchTerm = Model.ExtendedPageProperties["PageListingModel"].CurrentSearchTerm -%}
{%- assign currentCategoryFilter = "" -%}
{%- if Model.ExtendedPageProperties["PageListingModel"].SelectedCategoryIds != null and Model.ExtendedPageProperties["PageListingModel"].SelectedCategoryIds.size > 0 -%}
  {%- assign currentCategoryFilter = Model.ExtendedPageProperties["PageListingModel"].SelectedCategoryIds | first -%}
{%- endif -%}

<form id="resource-filter-form" class="resource-filters" method="get" action="{{ currentRoute }}">

  <select id="category-filter" name="categoryFilter" class="filter-select">
    <option value="">All Topics</option>
    {%- for catref in Model.CurrentPage.AvailableFilterBy -%}
      {%- assign catChildList = ContentLoader.GetChildren(catref) -%}
      {%- for catChild in catChildList -%}
        <option value="{{ catChild.ContentLink }}"
          {%- if currentCategoryFilter == catChild.ContentLink %} selected="selected"{%- endif -%}>
          {{ catChild.Name }}
        </option>
      {%- endfor -%}
    {%- endfor -%}
  </select>

  <select id="year-filter" name="year" class="filter-select">
    <option value="">All Years</option>
    <option value="2026">2026</option>
    <option value="2025">2025</option>
    <option value="2024">2024</option>
  </select>

  <input type="search" id="search-filter" name="searchTerm" placeholder="Search resources…"
    value="{{ currentSearchTerm }}" class="filter-search-input">

  <input type="hidden" name="viewType" value="list">
  <input type="hidden" name="startDate" value="2020-01-01">

  <button type="submit" id="filter-button" class="filter-button">Filter</button>

  <a href="{{ currentRoute }}" id="clear-filters" class="clear-button" style="display:none;">Clear All</a>

</form>

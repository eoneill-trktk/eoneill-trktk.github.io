{%- assign currentRoute = Model.ExtendedPageProperties["PageListingModel"].ActivePageRoute | friendly_url -%}
{%- assign currentSearchTerm = Model.ExtendedPageProperties["PageListingModel"].CurrentSearchTerm -%}

{%- comment %} ── Page context detection ───────────────────────────────── {%- endcomment %}
{%- assign pageContext = "resources" -%}
{%- if currentRoute contains "/resource-library-archives" -%}
  {%- assign pageContext = "archives" -%}
{%- elsif currentRoute contains "/topics/" -%}
  {%- assign pageContext = "topics" -%}
{%- elsif currentRoute contains "/news/" -%}
  {%- assign pageContext = "news" -%}
{%- elsif currentRoute contains "/category/" -%}
  {%- assign pageContext = "category" -%}
{%- endif -%}

{%- comment %} ── Topic slug — use URLSegment directly, no URL parsing needed ─ {%- endcomment %}
{%- assign topicSlug = "" -%}
{%- if pageContext == "topics" or pageContext == "category" -%}
  {%- assign topicSlug = Model.CurrentPage.URLSegment | downcase -%}
{%- endif -%}

{%- comment %} ── Dynamic year calculation ─────────────────────────────── {%- endcomment %}
{%- assign currentYear = 'now' | date: "%Y" | plus: 0 -%}
{%- assign priorYear = currentYear | minus: 1 -%}
{%- assign archiveMaxYear = currentYear | minus: 2 -%}

<form id="resource-filter-form" class="resource-filters" method="get" action="{{ currentRoute }}"
  data-page-context="{{ pageContext }}"
  data-topic-slug="{{ topicSlug }}"
  data-current-year="{{ currentYear }}">

  <select id="category-filter" class="filter-select">
    <option value="">All Topics</option>
    {%- for catref in Model.CurrentPage.AvailableFilterBy -%}
      {%- assign catChildList = ContentLoader.GetChildren(catref) -%}
      {%- for catChild in catChildList -%}
        {%- assign catSlug = catChild.Name | downcase | replace: " ", "-" -%}
        <option value="{{ catChild.ContentLink }}" data-slug="{{ catSlug }}">{{ catChild.Name }}</option>
      {%- endfor -%}
    {%- endfor -%}
  </select>

  <select id="year-filter" class="filter-select">
    <option value="">All Years</option>
    {%- if pageContext == "archives" -%}
      {%- comment %} Archives: show archiveMaxYear (e.g. 2024) down to 2020 {%- endcomment %}
      {%- assign y = archiveMaxYear -%}
      {%- for i in (1..10) -%}
        {%- if y >= 2020 -%}
          <option value="{{ y }}">{{ y }}</option>
          {%- assign y = y | minus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- comment %} Resources/Topics/News: current year and prior year only {%- endcomment %}
      <option value="{{ currentYear }}">{{ currentYear }}</option>
      <option value="{{ priorYear }}">{{ priorYear }}</option>
    {%- endif -%}
  </select>

  <input type="search" id="search-filter" name="searchTerm" placeholder="Search resources…"
    value="{{ currentSearchTerm }}" class="filter-search-input">

  <input type="hidden" name="viewType" value="list">
  <input type="hidden" name="startDate" value="2020-01-01">

  <button type="submit" id="filter-button" class="filter-button">Filter</button>

  <a href="{{ currentRoute }}" id="clear-filters" class="clear-button" style="display:none;">Clear All</a>

</form>

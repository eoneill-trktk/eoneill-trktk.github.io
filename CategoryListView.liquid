{%- comment %}
  CategoryListView.liquid
  Used by /category/* pages — news equivalent of TopicListView.
  Traverses up to find /all-mtf-news/, gets its children via ContentLoader,
  and renders them as resource cards. All filtering is client-side.
{%- endcomment %}

{%- comment %} Walk up: /category/slug/ → /category/ folder → site root → find /all-mtf-news/ {%- endcomment %}
{%- assign categoryFolder = ContentLoader.Get(Model.CurrentPage.ParentLink) -%}
{%- assign siteRootRef    = categoryFolder.ParentLink -%}
{%- assign siteChildren   = ContentLoader.GetChildren(siteRootRef) -%}
{%- assign newsRef        = null -%}
{%- for child in siteChildren -%}
  {%- if child.URLSegment == "all-mtf-news" -%}
    {%- assign newsRef = child.ContentLink -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- assign yearFolders = ContentLoader.GetChildren(newsRef) -%}

<div id="resource-grid-container" class="resource-grid">
{%- for yearFolder in yearFolders -%}
  {%- assign folderYear = yearFolder.URLSegment -%}
  {%- assign yearPages  = ContentLoader.GetChildren(yearFolder.ContentLink) -%}

  {%- for page in yearPages -%}

    {%- assign pageTitle = page.Name -%}
    {%- if page.PageTitle != null and page.PageTitle != "" -%}
      {%- assign pageTitle = page.PageTitle -%}
    {%- endif -%}
    {%- if pageTitle == null or pageTitle == "" -%}{%- continue -%}{%- endif -%}

    {%- assign catIds = "" -%}

    <article class="resource-card"
      data-year="{{ folderYear }}"
      data-category-ids="{{ catIds }}"
      data-title="{{ pageTitle | downcase }}"
      data-excerpt="">

      {%- assign img = null -%}
      {%- if page.PreviewImageFile != null -%}
        {%- assign img = page.PreviewImageFile | get_image -%}
      {%- endif -%}
      {%- assign thumbSrc = "/siteassets/images/mtf-logo-bg2x-100-600x400.jpg" -%}
      {%- assign thumbAlt = "MTF logo" -%}
      {%- if img != null and img.Url != null and img.Url != "" -%}
        {%- assign thumbSrc = img.Url -%}
        {%- assign thumbAlt = img.ImgAlt -%}
      {%- endif -%}
      <a class="resource-thumb" href="{{ page.LinkURL }}">
        <img loading="lazy" src="{{ thumbSrc }}" class="resource-thumb__img"
          alt="{{ thumbAlt }}" style="object-fit: cover;">
      </a>

      <div class="resource-body">
        {%- if page.Categories != null and page.Categories.size > 0 -%}
        <div class="resource-badges">
          {%- for catRef in page.Categories -%}
            {%- assign cat = ContentLoader.Get(catRef) -%}
            {%- if cat != null -%}
              {%- assign badgeSlug = cat.Name | downcase | replace: " ", "-" -%}
              {%- if catIds != "" -%}{%- assign catIds = catIds | append: "," -%}{%- endif -%}
              {%- assign catIds = catIds | append: cat.ContentLink -%}
              <span class="resource-badge cat-{{ badgeSlug }}">{{ cat.Name }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- endif -%}

        <h3 class="resource-title">
          <a href="{{ page.LinkURL }}">{{ pageTitle }}</a>
        </h3>

        {%- if page.PageSummary != null and page.PageSummary != "" -%}
        <div class="resource-excerpt">{{ page.PageSummary }}</div>
        {%- else -%}
        <div class="resource-excerpt"></div>
        {%- endif -%}

        <div class="resource-date">{{ page.ContentPostedDate | date: "%B %-d, %Y" }}</div>
      </div>
    </article>

  {%- endfor -%}
{%- endfor -%}
</div>

<div id="no-results-message" class="no-results" style="display:none;">
  <p style="color: #FF0000;">No content found.</p>
</div>
